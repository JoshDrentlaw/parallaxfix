# Hand Terminal — required runtime config. Copy to `.env` and fill in.
# Read via --allow-env. NEVER commit the filled-in .env (see .gitignore).

# Claude API — enrichment + synthesis (required for Phases 3–4)
ANTHROPIC_API_KEY=

# Reddit — free tier, non-commercial/research only (Phase 2)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=hand-terminal/0.1 (research)

# X / Twitter — OFF by default, Phase 5 only, pay-per-use. Leave blank to keep disabled.
X_BEARER_TOKEN=

# Corpus storage — Postgres + pgvector (Phase 1). One DB for the event log + vectors.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/handterminal

# Embeddings — local model via transformers.js. Weights cache under ./models on first run.
HAND_TERMINAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

# App settings
HAND_TERMINAL_DATA_DIR=./data

# Egress (provided by nucklehead host; do not unset/override to bypass TLS)
# HTTPS_PROXY=
# DENO_CERT=
