{
  // ─────────────────────────────────────────────────────────────────────────
  // Hand Terminal — Deno project + SECURITY POLICY (operational form).
  //
  // The permission flags baked into the tasks below ARE this application's
  // security policy in executable form. See SECURITY.md for the rationale and
  // the host-contract notes for nucklehead.
  //
  // Posture: BROAD BY DESIGN. Hand Terminal declares its own policy and is NOT
  // bound by the restrictive defaults applied to the `chores` app, nor by the
  // extended-but-still-limited grants given to `tower-expert`. Where this app
  // needs a capability, it claims it. The flags are enumerated (rather than a
  // bare `-A`) so the grant is intentional and auditable, but the enumerated
  // set is deliberately equivalent to full host capability.
  // ─────────────────────────────────────────────────────────────────────────

  "name": "hand-terminal",
  "version": "0.1.0",
  "exports": "./src/main.ts",

  // The single source of truth for the runtime permission grant. Tasks below
  // reference this set verbatim so the policy can't drift between entrypoints.
  //
  // Enumerated capabilities (each justified in SECURITY.md):
  //   --allow-net    outbound to ANY host  (RSS = arbitrary outlets; Bluesky
  //                  Jetstream WSS; Reddit; GDELT; X; Claude API; + the egress
  //                  proxy). An allowlist is intentionally NOT used: the set of
  //                  reachable hosts is open-ended by the app's nature.
  //   --allow-env    secrets + runtime config (ANTHROPIC_API_KEY, REDDIT_*,
  //                  X_* , HTTPS_PROXY, DENO_CERT, HAND_TERMINAL_*).
  //   --allow-read   config/topics, the SQLite store, local embedding model
  //                  files, the CA bundle.
  //   --allow-write  the append-only event log, vector index, and caches.
  //   --allow-sys    CPU/OS introspection used by embedding/ML threading.
  //   --allow-ffi    native extensions: sqlite-vec and the local embedding
  //                  runtime.
  //   --allow-run    subprocess escape hatch for local model tooling.
  //
  // `deno run -A src/main.ts` is the sanctioned equivalent and is acceptable
  // on nucklehead for this app; the enumerated form is preferred for legibility.

  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run src/main.ts",
    "brief": "deno run --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run src/main.ts brief",
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run src/main.ts",

    // Corpus commands use the local embedder (transformers.js → ONNX), whose
    // native deps need a node_modules dir. Same capability set as `start`;
    // --node-modules-dir is an install/runtime setting, not a new grant.
    "ingest": "deno run --node-modules-dir=auto --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run src/main.ts ingest",
    "match": "deno run --node-modules-dir=auto --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run src/main.ts match",

    // Dev-loop tasks. These need no runtime capabilities of their own.
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi --allow-run"
  },

  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },

  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },

  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "postgres": "npm:postgres@^3",
    "@huggingface/transformers": "npm:@huggingface/transformers@^3"
  }
}
